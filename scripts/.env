
# Path to the per-surah tafsir files directory (e.g. tafsir/ar-tafseer-al-qurtubi/1/1.json)
TAFSIR_DIR=tafsir

# Path to the complete tafsir JSONs directory (e.g. tafsir-complete/ar-tafseer-al-qurtubi/1.json)
TAFSIR_COMPLETE_DIR=tafsir-complete

# Example absolute overrides:
#TAFSIR_DIR=C:/Users/Ryder/Documents/GitHub/tafsir-the-Holy-Quran/tafsir
#TAFSIR_COMPLETE_DIR=C:/Users/Ryder/Documents/GitHub/tafsir-the-Holy-Quran/tafsir-complete
